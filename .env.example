# Chọn backend cho frontend. Copy file này thành .env.local rồi đổi giá trị.
#   VITE_API_TARGET=local   -> backend ở máy (https://localhost:7059)
#   VITE_API_TARGET=hosted  -> backend trên host (https://notaion.runasp.net)
# Không set: dev dùng local, build production dùng hosted.
VITE_API_TARGET=local
